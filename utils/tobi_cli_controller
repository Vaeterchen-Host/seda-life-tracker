"""This module contains the cli controller functions for SEDA."""
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
import ui.cli_view # pylint: disable=C0413
from model.classes import User, WaterLog, WeightLog # pylint: disable=C0413
from model.database import Database # pylint: disable=C0413

